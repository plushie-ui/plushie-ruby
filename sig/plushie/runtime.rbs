module Plushie
  class Runtime
    include Commands
    include Subscriptions

    @app: untyped
    @transport: Symbol | Array[untyped]
    @format: Symbol
    @daemon: bool
    @binary: String?
    @log_level: Symbol
    @token: String?
    @dev: bool
    @dev_dirs: Array[String]?
    @event_queue: Thread::Queue
    @model: untyped
    @previous_tree: Node?
    @bridge: Bridge?
    @dev_server: DevServer?
    @running: bool
    @async_tasks: Hash[Symbol, Hash[Symbol, untyped]]
    @pending_effects: Hash[String, Thread]
    @pending_timers: Hash[untyped, Thread]
    @subscriptions: Hash[untyped, Hash[Symbol, untyped]]
    @subscription_keys: Array[untyped]
    @canvas_widgets: Hash[String, CanvasWidget::RegistryEntry]
    @consecutive_errors: Integer
    @diagnostics: Array[Event::System]
    @diagnostics_mutex: Mutex
    @pending_stub_acks: Hash[String, Thread::Queue[untyped]]
    @pending_await_async: Hash[Symbol, Thread::Queue[untyped]]
    @pending_interact: Hash[Symbol, untyped]?
    @logger: Logger
    @loop_thread: Thread?

    def initialize: (
      app: untyped,
      ?transport: Symbol | Array[untyped],
      ?format: Symbol,
      ?daemon: bool,
      ?binary: String?,
      ?log_level: Symbol,
      ?token: String?,
      ?dev: bool,
      ?dev_dirs: Array[String]?
    ) -> void

    def run: () -> void
    def start: () -> Runtime
    def stop: () -> void
    def register_effect_stub: (String kind, untyped response, ?timeout: Numeric) -> :ok
    def unregister_effect_stub: (String kind, ?timeout: Numeric) -> :ok
    def get_diagnostics: () -> Array[Event::System]
    def interact: (String action, ?untyped selector, ?Hash[Symbol, untyped] payload, ?timeout: Numeric) -> Array[untyped]
    def await_async: (Symbol tag, ?timeout: Numeric) -> :ok

    private

    # Lifecycle
    def start_bridge: () -> void
    def start_dev_server: () -> void
    def initialize_app: () -> void

    # Event loop
    def event_loop: () -> void

    # Event dispatch
    def dispatch_event: (untyped event) -> void
    def handle_timer_tick: (untyped tag) -> void
    def handle_interact_step: (untyped response) -> void
    def handle_interact_response: (untyped response) -> void
    def handle_interact_request: (String action, untyped selector, Hash[Symbol, untyped] payload, Thread::Queue[untyped] result_queue) -> void
    def apply_event: (untyped event) -> void
    def extract_interact_events: (untyped response) -> Array[untyped]

    # Rendering
    def render_and_snapshot: () -> void
    def render_and_patch: () -> void
    def normalize_view_tree: ((Node | Array[Node] | nil) view_tree) -> Node

    # Result validation
    def unwrap_result: (untyped result) -> [untyped, Command::Cmd]

    # Async handling
    def handle_async_result: (Symbol tag, Integer nonce, untyped result) -> void
    def handle_stream_value: (Symbol tag, Integer nonce, untyped value) -> void
    def notify_await_async: (Symbol tag) -> void

    # Effect handling
    def handle_effect_timeout: (String id) -> void

    # Renderer exit
    def handle_renderer_exit: (untyped reason) -> void
    def fail_pending_interact: (String reason) -> void

    # Error handling
    def handle_callback_error: (String callback_name, Exception error, ?hint: String?) -> void
    def handle_view_error: (Exception error) -> void
    def resend_last_snapshot: () -> void

    # Shutdown
    def shutdown: () -> void

    module Commands
      private

      def execute_commands: (Command::Cmd? cmd) -> void
      def execute_async: (Proc callable, Symbol tag) -> void
      def execute_stream: (Proc callable, Symbol tag) -> void
      def cancel_task: (Symbol tag) -> void
      def execute_done: (untyped value, Proc mapper) -> void
      def execute_send_after: (Integer delay_ms, untyped event) -> void
      def execute_effect: (Hash[Symbol, untyped] payload) -> void
      def send_widget_op: (Symbol op, Hash[Symbol, untyped] payload) -> void
      def send_window_op: (Hash[Symbol, untyped] payload) -> void
      def send_window_query: (Hash[Symbol, untyped] payload) -> void
      def send_system_op: (Hash[Symbol, untyped] payload) -> void
      def send_system_query: (Hash[Symbol, untyped] payload) -> void
      def send_image_op: (Hash[Symbol, untyped] payload) -> void
      def send_extension_command: (Hash[Symbol, untyped] payload) -> void
      def send_extension_commands: (Array[Hash[Symbol, untyped]] commands) -> void
      def send_advance_frame: (Integer timestamp) -> void
    end

    module Subscriptions
      private

      def sync_subscriptions: () -> void
      def diff_subscriptions: (Hash[untyped, Subscription::Sub] new_by_key, Array[untyped] new_sorted_keys) -> void
      def start_subscription: (Subscription::Sub spec) -> Hash[Symbol, untyped]
      def stop_subscription: (untyped key) -> void
      def start_timer_subscription: (Subscription::Sub spec) -> Hash[Symbol, untyped]
      def start_renderer_subscription: (Subscription::Sub spec) -> Hash[Symbol, untyped]
      def update_max_rates: (Hash[untyped, Subscription::Sub] new_by_key) -> void
      def check_max_rate: (untyped key, Subscription::Sub spec) -> void
    end
  end
end
