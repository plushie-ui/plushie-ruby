module Plushie
  module CanvasWidget
    META_KEY: Symbol
    PROPS_KEY: Symbol
    STATE_KEY: Symbol
    CW_TAG_PREFIX: String

    class RegistryEntry
      attr_reader widget_module: untyped
      attr_reader state: untyped
      attr_reader props: Hash[Symbol | String, untyped]

      def initialize: (widget_module: untyped, state: untyped, props: Hash[Symbol | String, untyped]) -> void
    end

    def self.widget_key: (String window_id, String widget_id) -> String
    def self.build: (untyped widget_module, String id, ?Hash[Symbol | String, untyped] props) -> Node
    def self.placeholder?: (Node node) -> bool
    def self.derive_registry: (Node? tree) -> Hash[String, RegistryEntry]
    def self.dispatch_through_widgets: (Hash[String, RegistryEntry] registry, untyped event) -> [untyped, Hash[String, RegistryEntry]]
    def self.collect_subscriptions: (Hash[String, RegistryEntry] registry) -> Array[Subscription::Sub]
    def self.widget_tag?: (String | Symbol tag) -> bool
    def self.parse_widget_tag: (String | Symbol tag) -> [String, String]?
    def self.handle_widget_timer: (Hash[String, RegistryEntry] registry, String | Symbol tag) -> [untyped, Hash[String, RegistryEntry]]?
    def self.render_placeholder: (
      Node node,
      String? window_id,
      String scoped_id,
      String local_id,
      Hash[String, RegistryEntry] registry
    ) -> [Node, RegistryEntry]?

    module ClassMethods
      def canvas_widget: (Symbol type_name) -> Symbol
      def canvas_widget_type: () -> Symbol?
    end

    private

    def self.collect_entries: (Node node, Hash[String, RegistryEntry] acc, String? current_window_id) -> void
    def self.build_handler_chain: (Hash[String, RegistryEntry] registry, String window_id, Array[String] scope, String event_id) -> Array[untyped]
    def self.walk_chain: (Hash[String, RegistryEntry] registry, untyped event, Array[[String, RegistryEntry]] chain) -> [untyped, Hash[String, RegistryEntry]]
    def self.safe_handle_event: (RegistryEntry entry, untyped event, String widget_id) -> [untyped, untyped]
    def self.resolve_emit_identity: (untyped event, String widget_id) -> [String, String, Array[String]]
    def self.split_widget_id: (String widget_id) -> [String, Array[String]]
    def self.normalize_emit_data: (untyped data) -> Hash[Symbol, untyped]
    def self.scope_to_widget_ids: (Array[String] scope) -> Array[String]
    def self.scope_to_id: (Array[String] scope, String id) -> String
    def self.namespace_tag: (Subscription::Sub sub, String widget_id) -> Subscription::Sub
    def self.extract_scope: (untyped event) -> Array[String]
    def self.extract_id: (untyped event) -> String
    def self.extract_window_id: (untyped event) -> String
    def self.split_widget_key: (String widget_key) -> Array[String]
  end
end
