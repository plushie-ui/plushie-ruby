module Plushie
  class Subscription
    class Sub
      attr_reader type: Symbol
      attr_reader tag: Symbol
      attr_reader interval: Integer?
      attr_reader max_rate: Integer?

      def initialize: (type: Symbol, tag: Symbol, ?interval: Integer?, ?max_rate: Integer?) -> void

      def key: () -> Array[untyped]
      def with_max_rate: (Integer rate) -> Sub
    end

    def self.every: (Integer interval_ms, Symbol tag) -> Sub
    def self.on_key_press: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_key_release: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_modifiers_changed: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_mouse_move: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_mouse_button: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_mouse_scroll: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_window_close: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_window_open: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_window_resize: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_window_focus: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_window_unfocus: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_window_move: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_touch: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_ime: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_theme_change: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_animation_frame: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_file_drop: (Symbol tag, ?max_rate: Integer?) -> Sub
    def self.on_event: (Symbol tag, ?max_rate: Integer?) -> Sub
  end
end
