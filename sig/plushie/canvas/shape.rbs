module Plushie
  module Canvas
    module Shape
      # -- Style helpers --

      class Dash
        attr_reader segments: Array[Numeric]
        attr_reader offset: Numeric

        def initialize: (segments: Array[Numeric], offset: Numeric) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class Stroke
        attr_reader color: untyped
        attr_reader width: Numeric
        attr_reader cap: String?
        attr_reader join: String?
        attr_reader dash: Dash?

        def initialize: (color: untyped, width: Numeric, ?cap: String?, ?join: String?, ?dash: Dash?) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class LinearGradient
        attr_reader from: Array[Numeric]
        attr_reader to: Array[Numeric]
        attr_reader stops: Array[Array[untyped]]

        def initialize: (from: Array[Numeric], to: Array[Numeric], stops: Array[Array[untyped]]) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class ShapeStyle
        attr_reader fill: untyped
        attr_reader stroke: untyped
        attr_reader opacity: Numeric?

        def initialize: (?fill: untyped, ?stroke: untyped, ?opacity: Numeric?) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class DragBounds
        attr_reader min_x: Numeric?
        attr_reader max_x: Numeric?
        attr_reader min_y: Numeric?
        attr_reader max_y: Numeric?

        def initialize: (?min_x: Numeric?, ?max_x: Numeric?, ?min_y: Numeric?, ?max_y: Numeric?) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class HitRect
        attr_reader x: Numeric
        attr_reader y: Numeric
        attr_reader w: Numeric
        attr_reader h: Numeric

        def initialize: (x: Numeric, y: Numeric, w: Numeric, h: Numeric) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class Interactive
        attr_reader id: String
        attr_reader on_click: bool?
        attr_reader on_hover: bool?
        attr_reader draggable: bool?
        attr_reader drag_axis: String?
        attr_reader drag_bounds: DragBounds?
        attr_reader cursor: String?
        attr_reader hover_style: ShapeStyle?
        attr_reader pressed_style: ShapeStyle?
        attr_reader tooltip: String?
        attr_reader a11y: untyped
        attr_reader hit_rect: HitRect?

        def initialize: (
          id: String,
          ?on_click: bool?,
          ?on_hover: bool?,
          ?draggable: bool?,
          ?drag_axis: String?,
          ?drag_bounds: DragBounds?,
          ?cursor: String?,
          ?hover_style: ShapeStyle?,
          ?pressed_style: ShapeStyle?,
          ?tooltip: String?,
          ?a11y: untyped,
          ?hit_rect: HitRect?
        ) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      # -- Shape structs --

      class Rect
        attr_reader x: Numeric
        attr_reader y: Numeric
        attr_reader w: Numeric
        attr_reader h: Numeric
        attr_reader fill: untyped
        attr_reader stroke: untyped
        attr_reader stroke_width: Numeric?
        attr_reader opacity: Numeric?
        attr_reader interactive: Interactive?

        def initialize: (x: Numeric, y: Numeric, w: Numeric, h: Numeric, ?fill: untyped, ?stroke: untyped, ?stroke_width: Numeric?, ?opacity: Numeric?, ?interactive: Interactive?) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class Circle
        attr_reader x: Numeric
        attr_reader y: Numeric
        attr_reader r: Numeric
        attr_reader fill: untyped
        attr_reader stroke: untyped
        attr_reader stroke_width: Numeric?
        attr_reader opacity: Numeric?
        attr_reader interactive: Interactive?

        def initialize: (x: Numeric, y: Numeric, r: Numeric, ?fill: untyped, ?stroke: untyped, ?stroke_width: Numeric?, ?opacity: Numeric?, ?interactive: Interactive?) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class Line
        attr_reader x1: Numeric
        attr_reader y1: Numeric
        attr_reader x2: Numeric
        attr_reader y2: Numeric
        attr_reader stroke: untyped
        attr_reader stroke_width: Numeric?
        attr_reader opacity: Numeric?
        attr_reader interactive: Interactive?

        def initialize: (x1: Numeric, y1: Numeric, x2: Numeric, y2: Numeric, ?stroke: untyped, ?stroke_width: Numeric?, ?opacity: Numeric?, ?interactive: Interactive?) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class CanvasText
        attr_reader x: Numeric
        attr_reader y: Numeric
        attr_reader content: String
        attr_reader fill: untyped
        attr_reader size: Numeric?
        attr_reader font: untyped
        attr_reader opacity: Numeric?
        attr_reader interactive: Interactive?

        def initialize: (x: Numeric, y: Numeric, content: String, ?fill: untyped, ?size: Numeric?, ?font: untyped, ?opacity: Numeric?, ?interactive: Interactive?) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class Path
        attr_reader commands: Array[Array[untyped]]
        attr_reader fill: untyped
        attr_reader stroke: untyped
        attr_reader stroke_width: Numeric?
        attr_reader opacity: Numeric?
        attr_reader interactive: Interactive?

        def initialize: (commands: Array[Array[untyped]], ?fill: untyped, ?stroke: untyped, ?stroke_width: Numeric?, ?opacity: Numeric?, ?interactive: Interactive?) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class CanvasImage
        attr_reader source: String
        attr_reader x: Numeric
        attr_reader y: Numeric
        attr_reader w: Numeric
        attr_reader h: Numeric
        attr_reader rotation: Numeric?
        attr_reader opacity: Numeric?
        attr_reader interactive: Interactive?

        def initialize: (source: String, x: Numeric, y: Numeric, w: Numeric, h: Numeric, ?rotation: Numeric?, ?opacity: Numeric?, ?interactive: Interactive?) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class CanvasSvg
        attr_reader source: String
        attr_reader x: Numeric
        attr_reader y: Numeric
        attr_reader w: Numeric
        attr_reader h: Numeric
        attr_reader interactive: Interactive?

        def initialize: (source: String, x: Numeric, y: Numeric, w: Numeric, h: Numeric, ?interactive: Interactive?) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class Group
        attr_reader shapes: Array[untyped]
        attr_reader x: Numeric
        attr_reader y: Numeric
        attr_reader transform: untyped
        attr_reader clip: untyped
        attr_reader opacity: Numeric?
        attr_reader interactive: Interactive?

        def initialize: (shapes: Array[untyped], ?x: Numeric, ?y: Numeric, ?transform: untyped, ?clip: untyped, ?opacity: Numeric?, ?interactive: Interactive?) -> void
        def []: (Symbol key) -> untyped
        def to_wire: () -> Hash[Symbol, untyped]
      end

      # -- Transform commands --

      class PushTransform
        def initialize: () -> void
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class PopTransform
        def initialize: () -> void
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class Translate
        attr_reader x: Numeric
        attr_reader y: Numeric

        def initialize: (x: Numeric, y: Numeric) -> void
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class Rotate
        attr_reader angle: Numeric

        def initialize: (angle: Numeric) -> void
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class Scale
        attr_reader x: Numeric
        attr_reader y: Numeric

        def initialize: (x: Numeric, y: Numeric) -> void
        def to_wire: () -> Hash[Symbol, untyped]
      end

      # -- Clipping commands --

      class PushClip
        attr_reader x: Numeric
        attr_reader y: Numeric
        attr_reader w: Numeric
        attr_reader h: Numeric

        def initialize: (x: Numeric, y: Numeric, w: Numeric, h: Numeric) -> void
        def to_wire: () -> Hash[Symbol, untyped]
      end

      class PopClip
        def initialize: () -> void
        def to_wire: () -> Hash[Symbol, untyped]
      end

      # -- Builder functions --

      def self.rect: (Numeric x, Numeric y, Numeric w, Numeric h, **untyped opts) -> Rect

      def self.circle: (Numeric x, Numeric y, Numeric r, **untyped opts) -> Circle

      def self.line: (Numeric x1, Numeric y1, Numeric x2, Numeric y2, **untyped opts) -> Line

      def self.canvas_text: (Numeric x, Numeric y, String content, **untyped opts) -> CanvasText

      def self.path: (Array[Array[untyped]] commands, **untyped opts) -> Path

      def self.canvas_image: (String source, Numeric x, Numeric y, Numeric w, Numeric h, **untyped opts) -> CanvasImage

      def self.canvas_svg: (String source, Numeric x, Numeric y, Numeric w, Numeric h, **untyped opts) -> CanvasSvg

      def self.group: (Array[untyped] shapes, **untyped opts) -> Group

      # Path commands
      def self.move_to: (Numeric x, Numeric y) -> Array[untyped]

      def self.line_to: (Numeric x, Numeric y) -> Array[untyped]

      def self.close: () -> Array[String]

      def self.bezier_to: (Numeric cp1x, Numeric cp1y, Numeric cp2x, Numeric cp2y, Numeric x, Numeric y) -> Array[untyped]

      def self.quadratic_to: (Numeric cpx, Numeric cpy, Numeric x, Numeric y) -> Array[untyped]

      def self.arc: (Numeric cx, Numeric cy, Numeric r, Numeric start_angle, Numeric end_angle) -> Array[untyped]

      # Style helpers
      def self.stroke: (untyped color, Numeric width, **untyped opts) -> Stroke

      def self.linear_gradient: (Array[Numeric] from, Array[Numeric] to, Array[Array[untyped]] stops) -> LinearGradient

      # Transform commands
      def self.push_transform: () -> PushTransform

      def self.pop_transform: () -> PopTransform

      def self.translate: (Numeric x, Numeric y) -> Translate

      def self.rotate: (Numeric angle) -> Rotate

      def self.scale: (Numeric x, Numeric y) -> Scale

      # Clipping commands
      def self.push_clip: (Numeric x, Numeric y, Numeric w, Numeric h) -> PushClip

      def self.pop_clip: () -> PopClip
    end
  end
end
